# Anthropic API key — baked into the build at deploy time
# If set, skips the API key modal on load
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Login gate — if both are set, users must sign in before accessing the app
# VITE_APP_LOGIN is the plaintext username
# VITE_APP_PASSWORD_HASH is the SHA-256 hex hash of the password
# Generate the hash: printf '%s' 'yourpassword' | sha256sum
VITE_APP_LOGIN=CGU_Admin
VITE_APP_PASSWORD_HASH=your-sha256-hash-here
